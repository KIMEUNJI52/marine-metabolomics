# ===== 데이터 (원본은 git에 올리지 않음 - 용량/보안) =====
data/raw/*
data/interim/*
data/processed/*
!data/**/.gitkeep
# 집계 결과(소용량)는 커밋 - 재현/분석용
!data/processed/sst_dashboard.json
!data/processed/sst_monthly_by_sea.csv
!data/processed/sst_stations.json
!data/processed/sst_map_stations.json
# 원시 질량분석 파일
*.mzML
*.mzXML
*.raw
*.cdf
*.wiff
*.d/

# ===== 지도 원본/중간 GeoJSON (대용량) — 단순화본만 커밋 =====
data/geo/*-2018-geo.json
data/geo/*-2013-geo.json
data/geo/skorea-prov-0.01.json

# ===== 결과물 (대용량 산출물 제외, 폴더는 유지) =====
results/figures/*
results/tables/*
!results/**/.gitkeep
# 연도별 수온 지도 이미지는 커밋
!results/figures/korea_sst_yearly_*.png

# ===== Python =====
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
env/
*.egg-info/
.pytest_cache/

# ===== R =====
.Rhistory
.RData
.Rproj.user/
*.Rproj

# ===== conda =====
# 환경 자체는 environment.yml로 재현하므로 폴더는 올리지 않음

# ===== OS / 에디터 =====
.DS_Store
Thumbs.db
.vscode/
.idea/

# ===== 대용량/임시 =====
*.log
*.tmp
